# Two candidate Neon databases - inspect both, then pick one as the ingest target.
# Copy this file to .env and fill in the real values. NEVER commit .env.
DATABASE_URL_1=postgresql://USER:PASSWORD@HOST_1/neondb?sslmode=require&channel_binding=require
DATABASE_URL_2=postgresql://USER:PASSWORD@HOST_2/neondb?sslmode=require&channel_binding=require

# ISBNdb REST API key. Sign up at https://isbndb.com - paid plan required.
# Leave blank until acquired; the ingestion scripts will skip enrichment if unset.
ISBNDB_API_KEY=

# Anthropic API key for the query classifier (lib/query_classifier.py).
# Get one at https://console.anthropic.com - any tier works.
ANTHROPIC_API_KEY=
